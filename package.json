{
    "name": "dynamo",
    "scripts": {
        "test": "npm run test:php && npm run test:js",
        "test:php": "vendor/bin/phpunit",
        "test:js": "jest",
        "test:browser": "playwright test",
        "test:browser:headed": "playwright test --headed",
        "typecheck": "echo 'PHP project — no JS typecheck'",
        "build": "wp-scripts build src/admin/options.js --output-path=assets/js/options/",
        "start": "wp-scripts start src/admin/options.js --output-path=assets/js/options/"
    },
    "jest": {
        "testEnvironment": "jest-environment-jsdom",
        "testMatch": ["**/tests/js/**/*.test.js"],
        "setupFiles": ["./tests/js/setup/jquery-stub.js"]
    },
    "devDependencies": {
        "@playwright/test": "^1.59.1",
        "@wordpress/scripts": "^30.0.0",
        "jest": "^30.3.0",
        "jest-environment-jsdom": "^30.3.0"
    }
}
